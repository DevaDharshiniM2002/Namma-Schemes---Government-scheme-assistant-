# ============================================
# NAMMA SCHEME - FRONTEND ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values

# --------------------------------------------
# API CONFIGURATION
# --------------------------------------------

# Backend API Base URL
VITE_API_URL=http://localhost:8001
VITE_API_BASE_URL=http://localhost:8001/api

# API Timeout (in milliseconds)
VITE_API_TIMEOUT=30000

# --------------------------------------------
# APPLICATION CONFIGURATION
# --------------------------------------------

# App Name
VITE_APP_NAME=Namma Scheme

# App Version
VITE_APP_VERSION=1.0.0

# App Environment (development | production | staging)
VITE_APP_ENV=development

# App URL
VITE_APP_URL=http://localhost:5173

# --------------------------------------------
# LANGUAGE & LOCALIZATION
# --------------------------------------------

# Default Language
VITE_DEFAULT_LANGUAGE=en

# Supported Languages (comma-separated)
VITE_SUPPORTED_LANGUAGES=en,hi,ta

# Enable Multilingual Support
VITE_ENABLE_MULTILINGUAL=true

# --------------------------------------------
# AUTHENTICATION
# --------------------------------------------

# JWT Token Storage Key
VITE_TOKEN_STORAGE_KEY=namma_scheme_token

# User Data Storage Key
VITE_USER_STORAGE_KEY=namma_scheme_user

# Session Timeout (in minutes)
VITE_SESSION_TIMEOUT=30

# --------------------------------------------
# FEATURES FLAGS
# --------------------------------------------

# Enable AI Eligibility Checker
VITE_ENABLE_AI_CHECKER=true

# Enable Voice Search
VITE_ENABLE_VOICE_SEARCH=true

# Enable Dark Mode
VITE_ENABLE_DARK_MODE=true

# Enable Notifications
VITE_ENABLE_NOTIFICATIONS=true

# --------------------------------------------
# UI CONFIGURATION
# --------------------------------------------

# Items per page (pagination)
VITE_ITEMS_PER_PAGE=12

# Max items per page
VITE_MAX_ITEMS_PER_PAGE=50

# Toast Duration (in milliseconds)
VITE_TOAST_DURATION=3000

# --------------------------------------------
# FILE UPLOAD
# --------------------------------------------

# Max File Size (in MB)
VITE_MAX_FILE_SIZE=5

# Allowed File Types
VITE_ALLOWED_FILE_TYPES=.pdf,.jpg,.jpeg,.png,.doc,.docx

# --------------------------------------------
# SEARCH & FILTER
# --------------------------------------------

# Search Debounce Time (in milliseconds)
VITE_SEARCH_DEBOUNCE=500

# Min Search Characters
VITE_MIN_SEARCH_CHARS=2

# --------------------------------------------
# GOOGLE SERVICES (Optional)
# --------------------------------------------

# Google Analytics ID
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Google Maps API Key
# VITE_GOOGLE_MAPS_API_KEY=your_api_key_here

# Google reCAPTCHA Site Key
# VITE_RECAPTCHA_SITE_KEY=your_site_key_here

# --------------------------------------------
# CONTACT & SUPPORT
# --------------------------------------------

# Support Email
VITE_SUPPORT_EMAIL=support@nammascheme.com

# Contact Phone
VITE_CONTACT_PHONE=+91-1800-XXX-XXXX

# --------------------------------------------
# DEBUGGING
# --------------------------------------------

# Enable Debug Mode
VITE_DEBUG_MODE=true

# Enable Console Logs
VITE_ENABLE_CONSOLE_LOGS=true

# --------------------------------------------
# NOTES
# --------------------------------------------
# 1. All Vite env variables must start with VITE_
# 2. Restart dev server after changing variables
# 3. Use .env.local for local overrides
# ============================================
