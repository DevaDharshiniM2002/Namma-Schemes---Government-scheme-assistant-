# ============================================
# NAMMA SCHEME - BACKEND ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your actual values

# --------------------------------------------
# DATABASE CONFIGURATION
# --------------------------------------------

# MongoDB Atlas (Cloud Database) - Recommended for Production
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# Local MongoDB - Development
MONGO_URI=mongodb://localhost:27017/namma_scheme

# Database Name
DB_NAME=namma_scheme

# --------------------------------------------
# SERVER CONFIGURATION
# --------------------------------------------

# Backend Server Port
PORT=8001

# Node Environment (development | production | test)
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# --------------------------------------------
# AUTHENTICATION & SECURITY
# --------------------------------------------

# JWT Secret Key (Change this in production!)
JWT_SECRET=your_super_secret_jwt_key_here

# JWT Expiration Time
JWT_EXPIRES_IN=7d

# Password Salt Rounds (bcrypt)
SALT_ROUNDS=10

# --------------------------------------------
# AI & API KEYS
# --------------------------------------------

# Google Gemini AI API Key (for eligibility checker)
# Get your key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model Version
GEMINI_MODEL=gemini-pro

# --------------------------------------------
# FILE UPLOAD CONFIGURATION
# --------------------------------------------

# Maximum file upload size (in MB)
MAX_FILE_SIZE=5

# Allowed file types for document upload
ALLOWED_FILE_TYPES=.pdf,.jpg,.jpeg,.png,.doc,.docx

# Upload directory path
UPLOAD_DIR=./uploads

# --------------------------------------------
# EMAIL CONFIGURATION (Optional - for future use)
# --------------------------------------------

# SMTP Configuration
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password
# EMAIL_FROM=noreply@nammascheme.com

# --------------------------------------------
# LOGGING & MONITORING
# --------------------------------------------

# Log Level (error | warn | info | debug)
LOG_LEVEL=info

# Enable Request Logging
ENABLE_REQUEST_LOGGING=true

# --------------------------------------------
# RATE LIMITING
# --------------------------------------------

# API Rate Limit (requests per window)
RATE_LIMIT_MAX=100

# Rate Limit Window (in minutes)
RATE_LIMIT_WINDOW=15

# --------------------------------------------
# SESSION CONFIGURATION
# --------------------------------------------

# Session Secret
SESSION_SECRET=your_session_secret_here

# Session Max Age (in milliseconds) - 24 hours
SESSION_MAX_AGE=86400000

# --------------------------------------------
# CORS CONFIGURATION
# --------------------------------------------

# Allowed Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --------------------------------------------
# CACHE CONFIGURATION
# --------------------------------------------

# Cache TTL (Time To Live in seconds)
CACHE_TTL=3600

# Enable Caching
ENABLE_CACHE=true

# --------------------------------------------
# PAGINATION
# --------------------------------------------

# Default page size for API responses
DEFAULT_PAGE_SIZE=20

# Maximum page size
MAX_PAGE_SIZE=100

# --------------------------------------------
# MONGODB ATLAS CREDENTIALS (Backup)
# --------------------------------------------

# Atlas Username
ATLAS_USERNAME=your_username

# Atlas Password
ATLAS_PASSWORD=your_password

# Atlas Cluster URL
ATLAS_CLUSTER=your_cluster.mongodb.net

# --------------------------------------------
# ADMIN CONFIGURATION
# --------------------------------------------

# Default Admin Email
ADMIN_EMAIL=admin@nammascheme.com

# Default Admin Password (Change after first login!)
ADMIN_PASSWORD=change_this_password

# --------------------------------------------
# FEATURE FLAGS
# --------------------------------------------

# Enable AI Eligibility Checker
ENABLE_AI_CHECKER=true

# Enable Voice Search
ENABLE_VOICE_SEARCH=true

# Enable Multilingual Support
ENABLE_MULTILINGUAL=true

# Supported Languages (comma-separated)
SUPPORTED_LANGUAGES=en,hi,ta

# --------------------------------------------
# BACKUP & MAINTENANCE
# --------------------------------------------

# Auto Backup Enabled
AUTO_BACKUP=false

# Backup Interval (in hours)
BACKUP_INTERVAL=24

# Backup Directory
BACKUP_DIR=./backups

# --------------------------------------------
# ANALYTICS & TRACKING (Optional)
# --------------------------------------------

# Google Analytics ID
# GA_TRACKING_ID=UA-XXXXXXXXX-X

# Enable Analytics
# ENABLE_ANALYTICS=false

# --------------------------------------------
# NOTES
# --------------------------------------------
# 1. Never commit .env file to public repositories
# 2. Change all secrets before deploying to production
# 3. Use strong passwords and API keys
# 4. Keep this file secure and backed up
# 5. Update MongoDB Atlas IP whitelist as needed
# ============================================
