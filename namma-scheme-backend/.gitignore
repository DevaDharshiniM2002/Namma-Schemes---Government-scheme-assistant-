# ============================================
# NAMMA SCHEME - GIT IGNORE FILE
# ============================================

# --------------------------------------------
# ENVIRONMENT & SECRETS
# --------------------------------------------
.env
.env.local
.env.production
.env.development
.env.test
*.env

# Backup of env files
.env.backup
.env.old

# --------------------------------------------
# DEPENDENCIES
# --------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# --------------------------------------------
# LOGS
# --------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# --------------------------------------------
# RUNTIME DATA
# --------------------------------------------
pids/
*.pid
*.seed
*.pid.lock

# --------------------------------------------
# COVERAGE & TESTING
# --------------------------------------------
coverage/
*.lcov
.nyc_output/
.grunt/
.lock-wscript

# --------------------------------------------
# BUILD OUTPUT
# --------------------------------------------
dist/
build/
out/
.next/
.nuxt/
.cache/
.parcel-cache/
.vuepress/dist/

# --------------------------------------------
# DATABASE
# --------------------------------------------
*.sqlite
*.sqlite3
*.db
data/
mongodb-data/

# MongoDB dumps
dump/
*.bson
*.json.gz

# --------------------------------------------
# UPLOADS & TEMP FILES
# --------------------------------------------
uploads/
temp/
tmp/
*.tmp
*.temp

# --------------------------------------------
# BACKUPS
# --------------------------------------------
backups/
*.backup
*.bak
*.old

# --------------------------------------------
# OS FILES
# --------------------------------------------

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.directory
.Trash-*

# --------------------------------------------
# IDE & EDITOR FILES
# --------------------------------------------

# VSCode
.vscode/
*.code-workspace
.history/

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~
.netrwhist

# Emacs
*~
\#*\#
.\#*

# --------------------------------------------
# CERTIFICATES & KEYS
# --------------------------------------------
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
ssl/
certs/

# SSH keys
id_rsa
id_rsa.pub
*.ppk

# --------------------------------------------
# DOCKER
# --------------------------------------------
docker-compose.override.yml
.dockerignore

# --------------------------------------------
# MISC
# --------------------------------------------
.cache/
.temp/
.sass-cache/
*.css.map
*.js.map

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# --------------------------------------------
# SECURITY & SENSITIVE DATA
# --------------------------------------------
secrets/
credentials/
*.credentials
api-keys.txt
passwords.txt

# --------------------------------------------
# PROJECT SPECIFIC
# --------------------------------------------

# Scheme images (if large)
# public/images/schemes/*.jpg
# public/images/schemes/*.png

# User uploaded documents
user-uploads/
documents/

# Session files
sessions/

# --------------------------------------------
# KEEP THESE FILES
# --------------------------------------------
!.env.example
!.gitkeep
!README.md

# ============================================
# END OF .gitignore
# ============================================
